<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | NexoraCloud</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Exact same styling as login for consistency */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: #020205; color: #fff; display: flex; height: 100vh; overflow: hidden; }
        .auth-left { flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 4rem; position: relative; z-index: 2; }
        .auth-container { max-width: 400px; width: 100%; margin: 0 auto; }
        .logo { font-size: 1.5rem; font-weight: 700; color: #fff; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 3rem; }
        .logo i { color: #9d34ff; }
        .auth-title { font-size: 2.2rem; font-weight: 700; margin-bottom: 0.5rem; }
        .auth-desc { color: #8a8a98; margin-bottom: 2rem; font-size: 0.95rem; }
        .form-group { margin-bottom: 1.5rem; }
        label { display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.5rem; color: #8a8a98; }
        input { width: 100%; padding: 0.8rem 1rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; color: white; font-family: inherit; font-size: 0.95rem; outline: none; transition: 0.3s; }
        input:focus { border-color: #9d34ff; background: rgba(255,255,255,0.05); }
        .auth-btn { width: 100%; background: #9d34ff; color: white; border: none; padding: 1rem; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: 0.3s; margin-top: 1rem; font-family: 'DM Sans', sans-serif; }
        .auth-btn:hover { background: #b05cff; box-shadow: 0 5px 15px rgba(157, 52, 255, 0.4); }
        .auth-links { margin-top: 2rem; text-align: center; font-size: 0.9rem; color: #8a8a98; }
        .auth-links a { color: #9d34ff; font-weight: 700; text-decoration: none; }
        .alert { padding: 1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.8rem; }
        .alert-error { background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 1px solid rgba(244, 63, 94, 0.3); }
        
        .auth-right { flex: 1.2; background: url('https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=2070&auto=format&fit=crop') center/cover no-repeat; position: relative; display: none; }
        .auth-right::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, #020205 0%, rgba(2,2,5,0.4) 100%); }
        .auth-right::after { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(157, 52, 255, 0.15) 0%, transparent 60%); }
        @media (min-width: 900px) { .auth-right { display: block; } }
    </style>
</head>
<body>
    <div class="auth-left">
        <div class="auth-container">
            <a href="/" class="logo"><i class="fa-solid fa-cloud"></i> NexoraCloud</a>
            <h2 class="auth-title">Create Account</h2>
            <p class="auth-desc">Join NexoraCloud and deploy your server instantly.</p>

            <% if (error_msg && error_msg.length > 0) { %>
                <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error_msg %></div>
            <% } %>

            <form action="/register" method="POST">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required placeholder="Choose a username">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required placeholder="••••••••">
                </div>
                <button type="submit" class="auth-btn">Create Account</button>
            </form>

            <div class="auth-links">
                Already have an account? <a href="/login">Sign in here</a>
            </div>
        </div>
    </div>
    <div class="auth-right"></div>
</body>
</html>