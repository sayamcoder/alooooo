                        <%= cat.name %>
                    </button>
                <% }) %>
            </div>

            <!-- Dynamic Category Content Rendered from Database -->
            <% categories.forEach((cat, index) => { %>
                <div class="tab-content <%= index === 0 ? 'active' : '' %>" id="<%= cat.slug %>">
                    <p class="plan-subtitle"><%= cat.description || cat.name.toUpperCase() %></p>
                    <div class="game-plans-grid">
                        <% const catPlans = plans.filter(p => p.category_slug === cat.slug); %>
                        <% if (catPlans.length === 0) { %>
                            <p style="text-align: center; color: var(--text-muted); font-size: 0.9rem; grid-column: span 3; padding: 2rem;">No plans configured for this category yet.</p>
                        <% } %>
                        <% catPlans.forEach(plan => { %>
                            <div class="game-plan-card">
                                <div class="plan-header">
                                    <h3><i class="fa-solid fa-cube tier-3"></i> <%= plan.name %></h3>
                                    <div class="plan-price"><%= plan.price %><span>/mo</span></div>
                                </div>
                                <ul class="plan-features">
                                    <% plan.features.split('\n').forEach(feature => { %>
